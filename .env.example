# Variables de entorno para RETO_VISUALIZACION
# Copia este archivo a .env y rellena con tus valores reales

# ========== TOMTOM API ==========
# Obtén tu API key gratuita en: https://developer.tomtom.com/
# Incluye tráfico en tiempo real en el portal de TomTom
TOMTOM_API_KEY=tu_api_key_aqui

# ========== ELASTICSEARCH ==========
# URL donde está corriendo Elasticsearch
# En Docker: http://elasticsearch:9200
# En local: http://localhost:9200
ELASTIC_HOST=http://elasticsearch:9200
